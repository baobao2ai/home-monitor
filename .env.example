# Copy to .env and fill in your values
# cp .env.example .env

# Discord webhook for daily digest delivery
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Frigate RTSP password (used in camera URLs)
FRIGATE_RTSP_PASSWORD=changeme

# Storage path for clips (default: ./storage)
STORAGE_PATH=./storage

# How many days of clips to keep before auto-delete
CLIP_RETENTION_DAYS=30

# Daily digest time (cron format, default: 11 PM)
DIGEST_CRON=0 23 * * *
